APP_NAME="Tamil Nadu Vanigargalin Sangamam"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://vanigan.digital

# ========================================
# DATABASE: MySQL Voters DB (READ-ONLY)
# ========================================
DB_CONNECTION=mysql
DB_HOST=your_mysql_host
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password


# ========================================
# MONGODB (Atlas connection string)
# ========================================
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=vanigan

# ========================================
# CACHE & QUEUE
# ========================================
CACHE_STORE=redis
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# ========================================
# REDIS - PRODUCTION SERVER (original instance)
# ========================================
REDIS_CLIENT=predis
REDIS_HOST=striking-jaybird-66451.upstash.io
REDIS_PASSWORD=gQAAAAAAAQOTAAIncDFhYjE0MGIyOTk4ZTM0MGNhODNjYjFjMzM1ODgwZGIwMHAxNjY0NTE
REDIS_PORT=6379
REDIS_DB=0

# ========================================
# CLOUDINARY
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_SECRET=your_cloudinary_secret
CLOUDINARY_URL=cloudinary://key:secret@cloudname

# ========================================
# TWILIO (OTP Verification)
# ========================================
TWO_FACTOR_API_KEY=your_2factor_api_key

# ========================================
# ADMIN
# ========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password

# ========================================
# VANIGAM CONFIG (Reset Key)
# ========================================
VANIGAM_RESET_KEY=your_secure_reset_key_here

# ========================================
# APP CONFIG
# ========================================
BASE_URL=https://vanigan.digital

# ========================================
# LOGGING
# ========================================
LOG_CHANNEL=stack
LOG_LEVEL=warning

# NEW CLOUDINARY (Website Assets)
CLOUDINARY_ASSETS_CLOUD_NAME=your_assets_cloudinary_cloud_name
CLOUDINARY_ASSETS_API_KEY=your_assets_cloudinary_api_key
CLOUDINARY_ASSETS_API_SECRET=your_assets_cloudinary_api_secret
CLOUDINARY_ASSETS_URL=cloudinary://key:secret@cloudname
